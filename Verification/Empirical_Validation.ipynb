print('Environment ready.')

import numpy as np

DOMAIN_CONFIG = {
    "sar_aerial": {
        "attrs": ["battery", "comm", "payload", "risk"],
        # minimum acceptable value per attribute (risk is a MAX threshold)
        "thresholds": {"battery": 0.30, "comm": 0.40, "payload": 0.50, "risk": 0.70},
        "degrade_rate": {"battery": 0.02, "comm": 0.01, "payload": 0.0, "risk": 0.0},
    },
    "software_mas": {
        "attrs": ["cpu_headroom", "mem_headroom", "latency_budget", "risk"],
        "thresholds": {"cpu_headroom": 0.25, "mem_headroom": 0.25,
                       "latency_budget": 0.35, "risk": 0.75},
        "degrade_rate": {"cpu_headroom": 0.015, "mem_headroom": 0.01,
                          "latency_budget": 0.02, "risk": 0.0},
    },
}

WEIGHTS = {  # AHP-derived criteria weights (fixed, CR <= 0.1 as in section 3.4)
    "sar_aerial": {"battery": 0.30, "comm": 0.20, "payload": 0.30, "risk": 0.20},
    "software_mas": {"cpu_headroom": 0.30, "mem_headroom": 0.25,
                      "latency_budget": 0.25, "risk": 0.20},
}


def make_agent(rng, domain):
    cfg = DOMAIN_CONFIG[domain]
    # wider spread than a narrow "always-good" band so some candidates are
    # genuinely inadmissible -- this is what lets "invalid propagation" tell
    # the gated (AhToVik) architecture apart from the ungated (MAPE-K) one.
    a = {attr: rng.uniform(0.15, 1.0) for attr in cfg["attrs"]}
    a["risk"] = rng.uniform(0.0, 0.6)  # lower is better for risk
    return a


def feasible(agent, domain):
    """TOPSIS-style feasibility filter: admissibility conditions (V2 / V4 gate)."""
    cfg = DOMAIN_CONFIG[domain]
    for attr, thresh in cfg["thresholds"].items():
        if attr == "risk":
            if agent[attr] > thresh:
                return False
        else:
            if agent[attr] < thresh:
                return False
    return True


def compromise_score(agent, domain):
    """Modified-VIKOR-like compromise index; lower is better."""
    w = WEIGHTS[domain]
    score = 0.0
    for attr, weight in w.items():
        val = agent[attr]
        if attr == "risk":
            score += weight * val         # higher risk -> worse (higher score)
        else:
            score += weight * (1.0 - val)  # lower headroom -> worse
    return score


def degrade(agent, domain, rng, fault_rate):
    """Apply per-step degradation + probabilistic fault injection."""
    cfg = DOMAIN_CONFIG[domain]
    for attr, rate in cfg["degrade_rate"].items():
        agent[attr] = max(0.0, agent[attr] - rate)
    # fault injection: sudden drop in a random attribute
    if rng.random() < fault_rate:
        attr = rng.choice(cfg["attrs"])
        if attr == "risk":
            agent[attr] = min(1.0, agent[attr] + rng.uniform(0.2, 0.5))
        else:
            agent[attr] = max(0.0, agent[attr] - rng.uniform(0.3, 0.6))
    return agent


def violated_assumption(agent, domain):
    """Return the name of the (first) violated assumption, or None."""
    cfg = DOMAIN_CONFIG[domain]
    for attr, thresh in cfg["thresholds"].items():
        if attr == "risk":
            if agent[attr] > thresh:
                return attr
        else:
            if agent[attr] < thresh:
                return attr
    return None


def run_mission(rng, domain, architecture, n_agents, standby_pool_size,
                 fault_rate, max_steps=200,
                 v_check_cost=0.4,          # AhToVik: cost of one checkpoint eval
                 mapek_detect_delay=2.5,    # MAPE-K: post-hoc detection overhead
                 mapek_subsystem_cost=1.8,  # MAPE-K: separate recovery-subsystem call
                 max_recovery_cycles=5):
    """
    Simulate one mission lifecycle S0 -> S1 -> S2 -> S3 -> (V3 fail) -> S4 -> S2/S3 ...
    Returns a dict of metrics for this single trial.
    """
    cfg = DOMAIN_CONFIG[domain]
    assert architecture in ("ahtovik", "mapek")

    # ---- V1 / Planning (feasibility of the plan itself; assumed near-always
    # satisfiable if objectives/criteria are declared -- both architectures
    # pass this identically, so it does not differentiate the comparison) ----

    # ---- Candidate pool ----
    candidates = [make_agent(rng, domain) for _ in range(n_agents)]
    standby = [make_agent(rng, domain) for _ in range(standby_pool_size)]

    def pick_best(pool, gate):
        pool_f = [c for c in pool if feasible(c, domain)] if gate else list(pool)
        if not pool_f:
            return None, (len(pool) > 0)  # None, invalid_available_flag
        pool_f.sort(key=lambda c: compromise_score(c, domain))
        return pool_f[0], False

    # ---- V2 / Allocation ----
    if architecture == "ahtovik":
        assigned, _ = pick_best(candidates, gate=True)
        invalid_propagation = False
    else:  # mapek: no admissibility gate at allocation -- rank everyone, pick best
        pool_sorted = sorted(candidates, key=lambda c: compromise_score(c, domain))
        assigned = pool_sorted[0] if pool_sorted else None
        invalid_propagation = assigned is not None and not feasible(assigned, domain)

    if assigned is None:
        return dict(success=False, deadlock=True, recovery_latency=np.nan,
                     invalid_propagation=invalid_propagation,
                     traceability_time=np.nan, traceability_steps=np.nan,
                     recovery_cycles=0)

    total_recovery_latency = 0.0
    recovery_cycles = 0
    trace_time_samples = []
    trace_step_samples = []
    deadlock = False

    t = 0
    while t < max_steps:
        t += 1
        assigned = degrade(assigned, domain, rng, fault_rate)

        # ---- V3 / Runtime verification ----
        va = violated_assumption(assigned, domain)
        if va is None:
            continue  # pass -> mission continues

        # --- checkpoint failed: recovery needed ---
        recovery_cycles += 1
        if recovery_cycles > max_recovery_cycles:
            deadlock = True
            break

        if architecture == "ahtovik":
            # V3 failure is a named, structured event: violated assumption is
            # directly available from the checkpoint contract.
            trace_time_samples.append(0.05)
            trace_step_samples.append(1)

            # ---- V4 / Recovery verification: gate standby candidates ----
            promoted, invalid_avail = pick_best(standby, gate=True)
            latency = v_check_cost * 2  # V3 detection (immediate) + V4 evaluation
            if promoted is None:
                total_recovery_latency += latency
                deadlock = True
                break
            standby.remove(promoted)
            assigned = promoted
            total_recovery_latency += latency

        else:  # mapek
            # Observing-only: failure surfaces as a generic exception in an
            # unstructured event log; root cause must be located by search.
            log_size = rng.integers(15, 60)  # proxy for log verbosity
            trace_time_samples.append(0.05 * log_size)   # cost per entry scanned
            trace_step_samples.append(log_size)

            latency = mapek_detect_delay + mapek_subsystem_cost
            # no admissibility gate on the recovery candidate either
            pool_sorted = sorted(standby, key=lambda c: compromise_score(c, domain))
            promoted = pool_sorted[0] if pool_sorted else None
            if promoted is None:
                total_recovery_latency += latency
                deadlock = True
                break
            standby.remove(promoted)
            if not feasible(promoted, domain):
                invalid_propagation = True  # inadmissible candidate promoted
            assigned = promoted
            total_recovery_latency += latency

    success = (not deadlock) and (t >= max_steps or True)
    success = not deadlock

    return dict(
        success=success,
        deadlock=deadlock,
        recovery_latency=total_recovery_latency if recovery_cycles > 0 else 0.0,
        invalid_propagation=invalid_propagation,
        traceability_time=float(np.mean(trace_time_samples)) if trace_time_samples else np.nan,
        traceability_steps=float(np.mean(trace_step_samples)) if trace_step_samples else np.nan,
        recovery_cycles=recovery_cycles,
    )
import numpy as np
import pandas as pd
from scipy import stats

# ----------------------------------------------------------------------
# Experiment 1: sweep fault injection rate (recovery latency, success,
# invalid propagation) at a fixed, moderate standby pool size.
# ----------------------------------------------------------------------
def sweep_fault_rate(domains, architectures, fault_rates, n_trials=150,
                      n_agents=10, standby_pool_size=15, max_steps=60, seed=0):
    rng = np.random.default_rng(seed)
    rows = []
    for domain in domains:
        for arch in architectures:
            for fr in fault_rates:
                for _ in range(n_trials):
                    r = run_mission(rng, domain, arch, n_agents,
                                     standby_pool_size, fr, max_steps=max_steps)
                    r.update(domain=domain, architecture=arch, fault_rate=fr)
                    rows.append(r)
    return pd.DataFrame(rows)


# ----------------------------------------------------------------------
# Experiment 2: sweep standby pool size (deadlock rate) at a fixed,
# moderate fault rate.
# ----------------------------------------------------------------------
def sweep_pool_size(domains, architectures, pool_sizes, n_trials=150,
                     n_agents=10, fault_rate=0.03, max_steps=60, seed=1):
    rng = np.random.default_rng(seed)
    rows = []
    for domain in domains:
        for arch in architectures:
            for pool in pool_sizes:
                for _ in range(n_trials):
                    r = run_mission(rng, domain, arch, n_agents, pool,
                                     fault_rate, max_steps=max_steps)
                    r.update(domain=domain, architecture=arch, standby_pool=pool)
                    rows.append(r)
    return pd.DataFrame(rows)


def summarize(df, group_cols):
    agg = df.groupby(group_cols).agg(
        success_rate=("success", "mean"),
        deadlock_rate=("deadlock", "mean"),
        mean_recovery_latency=("recovery_latency", "mean"),
        mean_traceability_time=("traceability_time", "mean"),
        mean_traceability_steps=("traceability_steps", "mean"),
        invalid_propagation_rate=("invalid_propagation", "mean"),
        n=("success", "size"),
    ).reset_index()
    return agg


def mannwhitney_report(df, domain, metric="recovery_latency"):
    a = df[(df.domain == domain) & (df.architecture == "ahtovik")][metric].dropna()
    b = df[(df.domain == domain) & (df.architecture == "mapek")][metric].dropna()
    if len(a) < 5 or len(b) < 5:
        return domain, metric, np.nan, np.nan
    u, p = stats.mannwhitneyu(a, b, alternative="two-sided")
    return domain, metric, u, p
domains = ['sar_aerial', 'software_mas']
architectures = ['ahtovik', 'mapek']
fault_rates = [0.01, 0.02, 0.03, 0.05, 0.08]
pool_sizes = [6, 10, 15, 20, 25]
N_TRIALS = 300  # increase for tighter confidence intervals; 300 runs in seconds

df_fault = sweep_fault_rate(domains, architectures, fault_rates, n_trials=N_TRIALS)
df_pool = sweep_pool_size(domains, architectures, pool_sizes, n_trials=N_TRIALS)

print(f"df_fault: {len(df_fault)} trials, df_pool: {len(df_pool)} trials")
summary_fault = summarize(df_fault, ['domain', 'architecture', 'fault_rate'])
summary_pool = summarize(df_pool, ['domain', 'architecture', 'standby_pool'])

print("=== Fault-rate sweep (recovery latency, success, traceability, invalid propagation) ===")
display(summary_fault)

print("\n=== Standby-pool sweep (deadlock rate) ===")
display(summary_pool)
print(f"{'domain':<14}{'metric':<20}{'U':>14}{'p-value':>16}")
for domain in domains:
    for metric in ['recovery_latency', 'traceability_time']:
        d, m, u, p = mannwhitney_report(df_fault, domain, metric)
        p_str = f"{p:.3e}" if not np.isnan(p) else "n/a"
        print(f"{d:<14}{m:<20}{u:>14.1f}{p_str:>16}")
import matplotlib.pyplot as plt

COLORS = {"ahtovik": "#1f6feb", "mapek": "#d1495b"}
LABELS = {"ahtovik": "AhToVik (gated)", "mapek": "MAPE-K (observing-only)"}
DOMAIN_LABELS = {"sar_aerial": "SAR aerial agents", "software_mas": "Software MAS (microservices)"}


def make_comparison_figure(df_fault, df_pool, domains, out_path=None):
    fig, axes = plt.subplots(2, 3, figsize=(18, 10))

    # (0,0) Recovery latency vs fault rate
    ax = axes[0, 0]
    for domain in domains:
        for arch in ["ahtovik", "mapek"]:
            d = df_fault[(df_fault.domain == domain) & (df_fault.architecture == arch)]
            g = d.groupby("fault_rate")["recovery_latency"].mean()
            ls = "-" if domain == domains[0] else "--"
            ax.plot(g.index, g.values, marker="o", linestyle=ls,
                    color=COLORS[arch],
                    label=f"{LABELS[arch]} / {DOMAIN_LABELS[domain]}")
    ax.set_xlabel("Fault injection rate")
    ax.set_ylabel("Mean recovery latency (sim. time units)")
    ax.set_title("Recovery latency vs. fault rate")
    ax.legend(fontsize=7)

    # (0,1) Success rate vs fault rate
    ax = axes[0, 1]
    for domain in domains:
        for arch in ["ahtovik", "mapek"]:
            d = df_fault[(df_fault.domain == domain) & (df_fault.architecture == arch)]
            g = d.groupby("fault_rate")["success"].mean()
            ls = "-" if domain == domains[0] else "--"
            ax.plot(g.index, g.values, marker="o", linestyle=ls, color=COLORS[arch])
    ax.set_xlabel("Fault injection rate")
    ax.set_ylabel("Mission success rate")
    ax.set_title("Mission success vs. fault rate")
    ax.set_ylim(0, 1.05)

    # (0,2) Deadlock rate vs standby pool size
    ax = axes[0, 2]
    for domain in domains:
        for arch in ["ahtovik", "mapek"]:
            d = df_pool[(df_pool.domain == domain) & (df_pool.architecture == arch)]
            g = d.groupby("standby_pool")["deadlock"].mean()
            ls = "-" if domain == domains[0] else "--"
            ax.plot(g.index, g.values, marker="o", linestyle=ls, color=COLORS[arch])
    ax.set_xlabel("Standby pool size")
    ax.set_ylabel("Deadlock rate")
    ax.set_title("Deadlock rate vs. standby pool size\n(section 3.4 failure case)")
    ax.set_ylim(0, 1.05)

    # (1,0) Traceability time (bar)
    ax = axes[1, 0]
    labels, vals, colors = [], [], []
    for domain in domains:
        for arch in ["ahtovik", "mapek"]:
            d = df_fault[(df_fault.domain == domain) & (df_fault.architecture == arch)]
            labels.append(f"{arch}\n{domain}")
            vals.append(d["traceability_time"].mean())
            colors.append(COLORS[arch])
    ax.bar(labels, vals, color=colors)
    ax.set_ylabel("Mean traceability time (sim. cost units)")
    ax.set_title("Traceability: cost to identify\nviolated assumption from logs")
    ax.tick_params(axis="x", rotation=30, labelsize=8)

    # (1,1) Invalid propagation rate (bar)
    ax = axes[1, 1]
    labels, vals, colors = [], [], []
    for domain in domains:
        for arch in ["ahtovik", "mapek"]:
            d = df_fault[(df_fault.domain == domain) & (df_fault.architecture == arch)]
            labels.append(f"{arch}\n{domain}")
            vals.append(d["invalid_propagation"].mean())
            colors.append(COLORS[arch])
    ax.bar(labels, vals, color=colors)
    ax.set_ylabel("Invalid-decision propagation rate")
    ax.set_title("Candidates violating admissibility\nallowed to proceed (gating vs. observing)")
    ax.tick_params(axis="x", rotation=30, labelsize=8)
    ax.set_ylim(0, 1.0)

    # (1,2) Generalization: success rate across domains, both architectures,
    # at a fixed moderate fault rate -- shows the qualitative gap AhToVik vs
    # MAPE-K holds in both the aerial and the software-agent domain.
    ax = axes[1, 2]
    fr_fixed = sorted(df_fault.fault_rate.unique())[2]  # middle fault rate
    width = 0.35
    x = range(len(domains))
    for i, arch in enumerate(["ahtovik", "mapek"]):
        vals = []
        for domain in domains:
            d = df_fault[(df_fault.domain == domain) & (df_fault.architecture == arch)
                         & (df_fault.fault_rate == fr_fixed)]
            vals.append(d["success"].mean())
        offset = (i - 0.5) * width
        ax.bar([xi + offset for xi in x], vals, width=width, color=COLORS[arch],
               label=LABELS[arch])
    ax.set_xticks(list(x))
    ax.set_xticklabels([DOMAIN_LABELS[d] for d in domains], fontsize=8)
    ax.set_ylabel("Mission success rate")
    ax.set_title(f"Generalization across domains\n(fault rate = {fr_fixed})")
    ax.legend(fontsize=8)
    ax.set_ylim(0, 1.05)

    fig.suptitle("AhToVik (gated) vs. MAPE-K (observing-only): comparative simulation results",
                 fontsize=14, y=1.02)
    fig.tight_layout()
    if out_path:
        fig.savefig(out_path, dpi=150, bbox_inches="tight")
    return fig
   fig = make_comparison_figure(df_fault, df_pool, domains, out_path='ahtovik_vs_mapek_comparison.png')
   plt.show()
