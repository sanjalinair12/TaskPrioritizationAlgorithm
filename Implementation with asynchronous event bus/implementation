import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
from matplotlib.animation import FuncAnimation
from IPython.display import HTML, display

# --- 1. EXCEL DATA INGESTION ---
def get_input_from_excel():
    file_path = input("Enter the path to your Excel file (e.g., data.xlsx): ")
    try:
        df_criteria_comparison = pd.read_excel(file_path, sheet_name='Criteria Comparison', index_col=0)
        df_robots = pd.read_excel(file_path, sheet_name='Robots')
        df_tasks = pd.read_excel(file_path, sheet_name='Tasks', index_col=0)
        
        matrix = df_criteria_comparison.values
        robots = []
        for _, row in df_robots.iterrows():
            robots.append({
                'ID': str(row['ID']), 
                'Type': row['Type'], 
                'Values': row.iloc[2:].values.astype(float),
                'Pos': np.random.uniform(10, 90, 2)
            })
            
        tasks = []
        for index, row in df_tasks.iterrows():
            tasks.append({'Type': index, 'Scores': row.values.astype(float)})
            
        return matrix, robots, tasks
    except Exception as e:
        print(f"Error reading Excel file: {e}")
        return None

# --- 2. AHP & VIKOR MATHEMATICAL ENGINE ---
def calculate_metrics(matrix, robots, tasks):
    eigenvalues, eigenvectors = np.linalg.eig(matrix)
    weights = np.abs(eigenvectors[:, np.argmax(eigenvalues)])
    weights /= np.sum(weights)
    
    for t in tasks:
        t['Priority'] = np.dot(t['Scores'], weights)
    sorted_tasks = sorted(tasks, key=lambda x: x['Priority'], reverse=True)

    decision_matrix = np.array([r['Values'] for r in robots])
    weighted = decision_matrix * weights
    f_best, f_worst = np.max(weighted, axis=0), np.min(weighted, axis=0)
    
    S = np.sum((f_best - weighted) / (f_best - f_worst + 1e-9), axis=1)
    R = np.max((f_best - weighted) / (f_best - f_worst + 1e-9), axis=1)
    
    v = 0.5
    S_min, S_max = np.min(S), np.max(S)
    R_min, R_max = np.min(R), np.max(R)
    
    Q = v * (S - S_min) / (S_max - S_min + 1e-9) + \
        (1 - v) * (R - R_min) / (R_max - R_min + 1e-9)

    for i, r in enumerate(robots):
        r['Q_Index'] = np.round(Q[i], 4)
        
    return robots, sorted_tasks

# --- 3. ASYNCHRONOUS EVENT BUS ---
class EventBus:
    def __init__(self):
        self.listeners = {}
    
    def subscribe(self, event_type, callback):
        if event_type not in self.listeners:
            self.listeners[event_type] = []
        self.listeners[event_type].append(callback)
    
    def emit(self, event_type, data=None):
        if event_type in self.listeners:
            for callback in self.listeners[event_type]:
                callback(data)

# --- 4. RELIABLE COORDINATION ENGINE ---
class ReliableCoordinationEngine:
    def __init__(self, robots, sorted_tasks, bus):
        self.robots = robots
        self.sorted_tasks = sorted_tasks
        self.bus = bus
        self.active_status = {r['ID']: True for r in robots}
        self.assignments = {}
        self.bus.subscribe("STALL", self.handle_stall)
        self.reallocate()

    def handle_stall(self, rid):
        print(f"\n[EVENT BUS] ALERT: Robot {rid} stalled. Reallocating...")
        self.active_status[rid] = False
        self.reallocate()

    def reallocate(self):
        available = [r for r in self.robots if self.active_status[r['ID']]]
        dr = sorted([r for r in available if r['Type'] == 'Drone'], key=lambda x: x['Q_Index'])
        gr = sorted([r for r in available if r['Type'] == 'Ground Robot'], key=lambda x: x['Q_Index'])
        cr = sorted([r for r in available if r['Type'] == 'Creeper Robot'], key=lambda x: x['Q_Index'])

        new_asgn = {}
        for t in self.sorted_tasks:
            tt = t['Type']
            if tt == 'Scan and Rescue' and dr and len(gr) >= 2:
                for r_obj in [dr.pop(0), gr.pop(0), gr.pop(0)]: new_asgn[r_obj['ID']] = tt
            elif tt == 'Lifting Remains' and len(gr) >= 2:
                for r_obj in [gr.pop(0), gr.pop(0)]: new_asgn[r_obj['ID']] = tt
            elif tt == 'Supply Necessities' and gr and cr:
                for r_obj in [gr.pop(0), cr.pop(0)]: new_asgn[r_obj['ID']] = tt
        self.assignments = new_asgn

# --- 5. MAIN EXECUTION & VISUALIZATION ---
def main():
    data = get_input_from_excel()
    if not data: return
    matrix, robots_in, tasks_in = data

    robots, tasks = calculate_metrics(matrix, robots_in, tasks_in)
    bus = EventBus()
    engine = ReliableCoordinationEngine(robots, tasks, bus)

    colors = {'Scan and Rescue': 'magenta', 'Supply Necessities': 'orange', 'Lifting Remains': 'cyan'}
    t_pos = {'Scan and Rescue': [20, 80], 'Supply Necessities': [80, 80], 'Lifting Remains': [50, 20]}
    
    fig, ax = plt.subplots(figsize=(9, 7))

    def update(frame):
        ax.clear()
        ax.set_xlim(0, 100); ax.set_ylim(0, 100)
        
        # Draw Tasks
        for name, pos in t_pos.items():
            ax.add_patch(plt.Circle(pos, 5, color=colors[name], alpha=0.15))
            ax.text(pos[0]-8, pos[1]+7, name, fontweight='bold', fontsize=8)

        # Trigger Event at Frame 40
        if frame == 40:
            active_working = [rid for rid, t in engine.assignments.items() if engine.active_status.get(rid, False)]
            if active_working:
                bus.emit("STALL", active_working[0])

        # Render Fleet
        for r in robots:
            current_id = r['ID']
            task = engine.assignments.get(current_id)
            is_active = engine.active_status.get(current_id, False)
            
            if not is_active:
                ax.scatter(r['Pos'][0], r['Pos'][1], c='red', marker='x', s=150)
            else:
                c = colors.get(task, 'gray')
                ax.scatter(r['Pos'][0], r['Pos'][1], c=c, edgecolors='black', s=180, alpha=1 if task else 0.2)
                if task:
                    r['Pos'] += (np.array(t_pos[task]) - r['Pos']) * 0.04
            
            ax.text(r['Pos'][0]+2, r['Pos'][1]+2, f"{current_id}\nQ:{r['Q_Index']}", fontsize=7)

        ax.set_title(f"Fleet Coordination Engine | Frame {frame}")
        ax.grid(True, alpha=0.1)

    anim = FuncAnimation(fig, update, frames=100, interval=100)
    plt.close()
    return anim

# Execution
anim = main()
if anim:
    display(HTML(anim.to_jshtml()))
