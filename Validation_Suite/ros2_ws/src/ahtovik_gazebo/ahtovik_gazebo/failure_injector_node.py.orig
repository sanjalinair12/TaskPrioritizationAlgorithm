#!/usr/bin/env python3
import rclpy
from rclpy.node import Node
from std_msgs.msg import String

class FailureInjector(Node):
    def __init__(self):
        super().__init__('failure_injector')
        self.pub = self.create_publisher(String, '/ahtovik/failure_events', 10)
        self.timer = self.create_timer(12.0, self.inject_once)
        self.done = False

    def inject_once(self):
        if self.done:
            return
        msg = String(); msg.data = 'uav_0'
        self.pub.publish(msg)
        self.get_logger().warn('Injected failure for uav_0')
        self.done = True

def main(args=None):
    rclpy.init(args=args)
    node = FailureInjector()
    rclpy.spin(node)
    node.destroy_node()
    rclpy.shutdown()

if __name__ == '__main__':
    main()
