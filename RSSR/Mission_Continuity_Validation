import numpy as np
import pandas as pd
import random
import time
import matplotlib.pyplot as plt


# =========================================================
# SECTION 1: DATA INGESTION
# =========================================================

def get_input_from_excel():
    file_path = input("Enter the path to your Excel file: ")

    try:
        df_criteria = pd.read_excel(
            file_path,
            sheet_name="Criteria Comparison",
            index_col=0
        )

        df_robots = pd.read_excel(
            file_path,
            sheet_name="Robots"
        )

        df_tasks = pd.read_excel(
            file_path,
            sheet_name="Tasks",
            index_col=0
        )

        criteria_matrix = df_criteria.values.astype(float)

        eigenvalues, eigenvectors = np.linalg.eig(criteria_matrix)
        max_index = np.argmax(eigenvalues.real)

        weights = eigenvectors[:, max_index].real
        weights = np.abs(weights)
        weights = weights / np.sum(weights)

        robots = []
        for _, row in df_robots.iterrows():
            robots.append({
                "ID": row["ID"],
                "Type": row["Type"],
                "Values": row.iloc[2:].values.astype(float)
            })

        tasks = []
        for task_type, row in df_tasks.iterrows():
            tasks.append({
                "Type": task_type,
                "Scores": row.values.astype(float)
            })

        return weights, robots, tasks

    except Exception as e:
        print(f"Error while loading input file: {e}")
        return None


# =========================================================
# SECTION 2: AHTOVIK Q EVALUATION
# =========================================================

def evaluate_niche_authority(robots, task_scores, weights, v=0.5):
    decision_matrix = np.array([r["Values"] for r in robots])
    weighted_matrix = decision_matrix * weights * task_scores

    pis = np.max(weighted_matrix, axis=0)
    nis = np.min(weighted_matrix, axis=0)

    d_plus = np.sqrt(np.sum((weighted_matrix - pis) ** 2, axis=1))
    d_minus = np.sqrt(np.sum((weighted_matrix - nis) ** 2, axis=1))

    dp_min, dp_max = np.min(d_plus), np.max(d_plus)
    dm_min, dm_max = np.min(d_minus), np.max(d_minus)

    q_indices = []

    for i in range(len(d_plus)):
        t1 = (
            (d_plus[i] - dp_min) / (dp_max - dp_min)
            if (dp_max - dp_min) != 0
            else 0
        )

        t2 = (
            (dm_max - d_minus[i]) / (dm_max - dm_min)
            if (dm_max - dm_min) != 0
            else 0
        )

        q_indices.append(v * t1 + (1 - v) * t2)

    return q_indices


# =========================================================
# SECTION 3: TASK REQUIREMENTS AND ASSIGNMENT
# =========================================================

def get_task_requirements(task_name):
    if task_name == "Scan and Rescue":
        return {"Drone": 1, "Ground Robot": 2}
    elif task_name == "Supply Necessities":
        return {"Ground Robot": 1, "Creeper Robot": 1}
    elif task_name == "Lifting Remains":
        return {"Ground Robot": 2}
    else:
        return {}


def form_initial_task_assignments(available_robots, tasks):
    task_assignments = {}

    for task in tasks:
        task_name = task["Type"]
        requirements = get_task_requirements(task_name)

        sorted_for_task = sorted(
            available_robots,
            key=lambda x: x[f"Q_{task_name}"]
        )

        already_assigned = [
            r for team in task_assignments.values()
            for r in team
        ]

        team = []

        for robot_type, count in requirements.items():
            candidates = [
                r for r in sorted_for_task
                if r["Type"] == robot_type
                and r not in already_assigned
            ]

            selected = candidates[:count]
            team.extend(selected)
            already_assigned.extend(selected)

        task_assignments[task_name] = team

    return task_assignments


# =========================================================
# SECTION 4: RUNTIME MODEL
# =========================================================

def add_runtime_state_to_robots(robots, seed=42, severity="moderate"):
    random.seed(seed)

    runtime_robots = []

    for robot in robots:
        r = robot.copy()

        if severity == "minor":
            r["Battery"] = random.randint(40, 100)
            r["Communication"] = random.randint(60, 100)

        elif severity == "moderate":
            r["Battery"] = random.randint(25, 100)
            r["Communication"] = random.randint(40, 100)

        elif severity == "critical":
            r["Battery"] = random.randint(10, 100)
            r["Communication"] = random.randint(20, 100)

        else:
            r["Battery"] = random.randint(25, 100)
            r["Communication"] = random.randint(40, 100)

        r["Operational"] = True
        runtime_robots.append(r)

    return runtime_robots


def clone_assignments_with_runtime_robots(task_assignments, runtime_robots):
    id_to_robot = {r["ID"]: r for r in runtime_robots}

    return {
        task_name: [id_to_robot[r["ID"]] for r in team]
        for task_name, team in task_assignments.items()
    }


def get_active_agents(task_assignments):
    return [
        (task_name, robot)
        for task_name, team in task_assignments.items()
        for robot in team
    ]


def inject_failure_with_probability(task_assignments, failure_probability):
    active_agents = get_active_agents(task_assignments)

    if len(active_agents) == 0:
        return None, None, "no_active_agent"

    if random.random() > failure_probability:
        return None, None, "no_failure"

    failed_task, failed_robot = random.choice(active_agents)
    failed_robot["Operational"] = False

    return failed_task, failed_robot, "failure_injected"


def reduce_standby_pool(runtime_robots, task_assignments, standby_ratio=1.0):
    """
    Simulates limited standby availability.
    standby_ratio = 1.0 keeps all standby robots.
    standby_ratio = 0.1 keeps only 10% of standby robots.
    """
    assigned_ids = {
        r["ID"]
        for team in task_assignments.values()
        for r in team
    }

    active = [
        r for r in runtime_robots
        if r["ID"] in assigned_ids
    ]

    standby = [
        r for r in runtime_robots
        if r["ID"] not in assigned_ids
    ]

    keep_count = max(1, int(len(standby) * standby_ratio))
    kept_standby = random.sample(standby, keep_count)

    return active + kept_standby


# =========================================================
# SECTION 5: RECOVERY VERIFICATION
# =========================================================

def verify_candidate(candidate, failed_robot, verification_enabled=True):
    if candidate is None:
        return False, "no_candidate"

    if not verification_enabled:
        return True, "verification_disabled"

    if candidate["Type"] != failed_robot["Type"]:
        return False, "capability_mismatch"

    if candidate.get("Operational", True) is False:
        return False, "candidate_not_operational"

    if candidate.get("Battery", 100) < 30:
        return False, "battery_below_threshold"

    if candidate.get("Communication", 100) < 50:
        return False, "communication_below_threshold"

    return True, "verified"


def would_candidate_be_invalid(candidate, failed_robot):
    valid, _ = verify_candidate(
        candidate,
        failed_robot,
        verification_enabled=True
    )
    return not valid


# =========================================================
# SECTION 6: RECOVERY STRATEGIES
# =========================================================

def ahtovik_recovery(
    failed_task,
    failed_robot,
    current_assignments,
    runtime_robots,
    verification_enabled=True
):
    """
    AHTOVIK:
    Selects the same-type standby candidate with best task-specific Q.
    """
    start_time = time.time()

    already_assigned = [
        r for team in current_assignments.values()
        for r in team
    ]

    candidates = [
        r for r in runtime_robots
        if r not in already_assigned
        and r["Type"] == failed_robot["Type"]
    ]

    candidates = sorted(
        candidates,
        key=lambda x: x.get(f"Q_{failed_task}", float("inf"))
    )

    selected = candidates[0] if candidates else None

    invalid_without_verification = would_candidate_be_invalid(
        selected,
        failed_robot
    )

    verified, reason = verify_candidate(
        selected,
        failed_robot,
        verification_enabled
    )

    if not verified:
        return False, False, time.time() - start_time, selected, reason, invalid_without_verification

    current_assignments[failed_task] = [
        selected if r == failed_robot else r
        for r in current_assignments[failed_task]
    ]

    return True, True, time.time() - start_time, selected, reason, invalid_without_verification


def random_recovery(
    failed_task,
    failed_robot,
    current_assignments,
    runtime_robots,
    verification_enabled=True
):
    """
    Random recovery baseline:
    Random same-type standby promotion.
    """
    start_time = time.time()

    already_assigned = [
        r for team in current_assignments.values()
        for r in team
    ]

    candidates = [
        r for r in runtime_robots
        if r not in already_assigned
        and r["Type"] == failed_robot["Type"]
    ]

    selected = random.choice(candidates) if candidates else None

    invalid_without_verification = would_candidate_be_invalid(
        selected,
        failed_robot
    )

    verified, reason = verify_candidate(
        selected,
        failed_robot,
        verification_enabled
    )

    if not verified:
        return False, False, time.time() - start_time, selected, reason, invalid_without_verification

    current_assignments[failed_task] = [
        selected if r == failed_robot else r
        for r in current_assignments[failed_task]
    ]

    return True, True, time.time() - start_time, selected, reason, invalid_without_verification


def first_available_recovery(
    failed_task,
    failed_robot,
    current_assignments,
    runtime_robots,
    verification_enabled=True
):
    """
    First-available recovery baseline:
    Promotes the first same-type standby.
    """
    start_time = time.time()

    already_assigned = [
        r for team in current_assignments.values()
        for r in team
    ]

    candidates = [
        r for r in runtime_robots
        if r not in already_assigned
