def plot_line_summary(summary_df, x_col, y_col, title, xlabel, ylabel, filename):
    plt.figure(figsize=(8, 5))

    for algorithm in summary_df["algorithm"].unique():
        sub = summary_df[summary_df["algorithm"] == algorithm]
        plt.plot(
            sub[x_col],
            sub[y_col],
            marker="o",
            label=algorithm
        )

    plt.xlabel(xlabel)
    plt.ylabel(ylabel)
    plt.title(title)
    plt.ylim(0, 105)
    plt.grid(True)
    plt.legend()
    plt.tight_layout()
    plt.savefig(filename, dpi=300)
    plt.show()


def plot_bar_summary(summary_df, group_col, y_col, title, ylabel, filename):
    pivot = summary_df.pivot(
        index=group_col,
        columns="algorithm",
        values=y_col
    )

    pivot.plot(kind="bar", figsize=(9, 5))
    plt.ylabel(ylabel)
    plt.title(title)
    plt.ylim(0, 105)
    plt.grid(axis="y")
    plt.tight_layout()
    plt.savefig(filename, dpi=300)
    plt.show()


def plot_verification_ablation(ablation_summary):
    labels = []

    for _, row in ablation_summary.iterrows():
        mode = "ON" if row["verification_enabled"] else "OFF"
        labels.append(f"{row['algorithm']}\n{mode}")

    x = np.arange(len(labels))

    plt.figure(figsize=(10, 5))
    plt.bar(
        x,
        ablation_summary["Invalid Promotions"]
    )

    plt.xticks(x, labels, rotation=15)
    plt.ylabel("Invalid Promotions")
    plt.title("Verification ON/OFF Ablation")
    plt.grid(axis="y")
    plt.tight_layout()
    plt.savefig("verification_ablation_invalid_promotions.png", dpi=300)
    plt.show()


# =========================================================
# SECTION 10: MAIN
# =========================================================

def main():
    data = get_input_from_excel()

    if data is None:
        raise Exception("Input file could not be loaded.")

    weights, robots, tasks = data
    available_robots = list(robots)

    for task in tasks:
        task_name = task["Type"]

        q_values = evaluate_niche_authority(
            available_robots,
            task["Scores"],
            weights
        )

        for i, robot in enumerate(available_robots):
            robot[f"Q_{task_name}"] = q_values[i]

    task_assignments = form_initial_task_assignments(
        available_robots,
        tasks
    )

    print("\n--- Initial Task Assignments ---")
    for task_name, team in task_assignments.items():
        print(f"\n{task_name}")
        for robot in team:
            print(
                f"{robot['ID']} "
                f"{robot['Type']} "
                f"Q={robot[f'Q_{task_name}']:.4f}"
            )

    fp_results, fp_summary = run_failure_probability_experiment(
        task_assignments,
        available_robots,
        num_runs=500,
        seed=42
    )

    ablation_results, ablation_summary = run_verification_ablation(
        task_assignments,
        available_robots,
        num_runs=500,
        seed=42
    )

    severity_results, severity_summary = run_failure_severity_experiment(
        task_assignments,
        available_robots,
        num_runs=500,
        seed=42
    )

    standby_results, standby_summary = run_standby_pool_experiment(
        task_assignments,
        available_robots,
        num_runs=500,
        seed=42
    )

    print("\n--- Failure Probability Summary ---")
    print(fp_summary)

    print("\n--- Verification Ablation Summary ---")
    print(ablation_summary)

    print("\n--- Failure Severity Summary ---")
    print(severity_summary)

    print("\n--- Standby Pool Summary ---")
    print(standby_summary)

    fp_results.to_csv("rssr_failure_probability_results.csv", index=False)
    fp_summary.to_csv("rssr_failure_probability_summary.csv", index=False)

    ablation_results.to_csv("rssr_verification_ablation_results.csv", index=False)
    ablation_summary.to_csv("rssr_verification_ablation_summary.csv", index=False)

